# DigitalOcean Serverless function URL and auth token for async Slack dispatch
# Format: https://faas-<region>-<namespace>.doserverless.co/api/v1/web/<fn-id>/notion-crm/crm
DO_SLACK_ASYNC_URL=https://faas-<region>-<namespace>.doserverless.co/api/v1/web/<fn-id>/notion-crm/crm
# Format: Basic <base64(username:password)> — credentials for the DO function
DO_SLACK_ASYNC_TOKEN=Basic <base64-encoded-credentials>

# Anthropic API key for Claude agent
ANTHROPIC_API_KEY=sk-ant-...

# Perplexity API key (used for web search in agent)
PERPLEXITY_API_KEY=pplx-...

# Supabase project URL and service role key for logging
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# Shared secret for authenticating direct API calls to the DO function
API_SECRET=<your-api-secret>

# Slack app credentials
SLACK_SIGNING_SECRET=<slack-signing-secret>
SLACK_BOT_TOKEN=xoxb-<slack-bot-token>
